# Public tunnel hostname in Cloudflare DNS (orange cloud enabled)
TUNNEL_HOSTNAME=proxy.example.com

# Tunnel UUID from: cloudflared tunnel create my-proxy
TUNNEL_ID=00000000-0000-0000-0000-000000000000

# Credentials JSON created by cloudflared tunnel create
# Put file in cloudflared/ and point here.
TUNNEL_CREDENTIALS_FILE=./cloudflared/00000000-0000-0000-0000-000000000000.json

# Proxy auth for browser clients
PROXY_USER=proxyuser
PROXY_PASSWORD=ChangeMe_UseStrongPassword

# Comma-separated whitelist for squid dstdomain ACL
# Wildcard format in .env: *.target-site.com
# Example: target-site.com,*.target-site.com,api.target-site.com
ALLOWED_HOSTS=target-site.com,*.target-site.com

# Optional SOPS key path
SOPS_KEY_FILE=$HOME/.sops/key.txt
