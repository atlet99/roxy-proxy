# Public hostname in Cloudflare DNS (proxied/orange cloud)
TUNNEL_HOSTNAME=proxy.example.com

# Remote-managed tunnel name (Cloudflare API mode)
TUNNEL_NAME=roxy-proxy

# Filled automatically by `make cf-remote-tunnel`
TUNNEL_ID=
TUNNEL_TOKEN=

# Cloudflare IDs (used by API setup script)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Internal origin service seen by cloudflared inside Docker network
ORIGIN_SERVICE=https://nginx:8443
ORIGIN_SERVER_NAME=proxy.example.com
# true is safer for Docker-internal origin with CF Origin certs.
# set false only if strict origin TLS trust is fully configured.
ORIGIN_NO_TLS_VERIFY=true

# Proxy auth for browser clients
PROXY_USER=proxyuser
PROXY_PASSWORD=ChangeMe_UseStrongPassword

# Comma-separated whitelist for squid dstdomain ACL
# Wildcard format in .env: *.target-site.com
ALLOWED_HOSTS=target-site.com,*.target-site.com

# UFW behavior for scripts/setup-ufw.sh:
# 0 = tunnel-only mode (do not open 80/443), 1 = open 80/443
UFW_ALLOW_WEB_PORTS=0
